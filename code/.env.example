# UAOS Bootstrap .env (copy to .env and edit)

# Tract store name (defaults to repo dir name if empty)
TRACT_STORE=uaos

# Gateway HTTP port (used by message-gateway)
GATEWAY_PORT=8090

# Telegram (set a dummy token to satisfy local config validation; replace when wiring webhooks)
TELEGRAM_BOT_TOKEN=dev-local-dummy
TELEGRAM_SECRET_TOKEN=

# Twilio/WhatsApp (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Gateway JWT (required by message-gateway config validation; any random string for local/dev)
JWT_SECRET=dev-local-secret-change-me
